digraph backend_selector {
    rankdir=TB;
    node [fontname="Helvetica", fontsize=12];

    A   [label="What do I need?", shape=ellipse];
    B   [label="GUI required?", shape=diamond];
    LMS [label="LM Studio", shape=box, style=filled, fillcolor="#1a1a2e", color="#4a90d9", fontcolor="#e0e0e0"];
    C   [label="Multi-user / production?", shape=diamond];
    D   [label="NVIDIA or MI300X+?", shape=diamond];
    VL  [label="vLLM", shape=box, style=filled, fillcolor="#1a1a2e", color="#4a90d9", fontcolor="#e0e0e0"];
    LC  [label="llama.cpp", shape=box, style=filled, fillcolor="#1a1a2e", color="#4a90d9", fontcolor="#e0e0e0"];
    E   [label="Quick setup, team API?", shape=diamond];
    OL  [label="Ollama", shape=box, style=filled, fillcolor="#1a1a2e", color="#4a90d9", fontcolor="#e0e0e0"];
    F   [label="Full GPU + CPU control?", shape=diamond];

    A  -> B;
    B  -> LMS [label="Yes"];
    B  -> C   [label="No"];
    C  -> D   [label="Yes"];
    D  -> VL  [label="Yes"];
    D  -> LC  [label="No"];
    C  -> E   [label="No"];
    E  -> OL  [label="Yes"];
    E  -> F   [label="No"];
    F  -> LC  [label="Yes"];
    F  -> OL  [label="No"];
}
